# ---------------- Search ----------------
SEARCH_PROVIDER=brave
BRAVE_SEARCH_API_KEY=
SERPER_API_KEY=

# ---------------- LLM ----------------
# deepseek | openai | none
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-terra

# ---------------- App ----------------
DATABASE_PATH=data/regulatory_library.sqlite3
MAX_SEARCH_RESULTS=25
MAX_DEEP_SEARCH_RESULTS=60
DEEP_SEARCH_QUERIES=4
MAX_FETCH_CHARS=60000
REQUEST_TIMEOUT=25

# ---------------- Deployment security ----------------
# Optional locally; strongly recommended when deployed online.
APP_PASSWORD=
DEPLOYMENT_MODE=local
