# Paste these values into Streamlit Community Cloud > Advanced settings > Secrets.
# Never rename this example file to secrets.toml and commit it to GitHub.

SEARCH_PROVIDER = "brave"
BRAVE_SEARCH_API_KEY = "replace-with-your-brave-key"
SERPER_API_KEY = ""

LLM_PROVIDER = "deepseek"
DEEPSEEK_API_KEY = "replace-with-your-deepseek-key"
DEEPSEEK_MODEL = "deepseek-chat"
OPENAI_API_KEY = ""
OPENAI_MODEL = ""

# Strongly recommended for any internet-accessible deployment.
APP_PASSWORD = "replace-with-a-long-private-password"
DEPLOYMENT_MODE = "cloud_demo"

DATABASE_PATH = "data/regulatory_library.sqlite3"
MAX_SEARCH_RESULTS = "25"
MAX_DEEP_SEARCH_RESULTS = "60"
DEEP_SEARCH_QUERIES = "4"
MAX_FETCH_CHARS = "60000"
REQUEST_TIMEOUT = "25"
